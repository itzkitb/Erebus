@page "/record/new/password"
@layout MainLayout
@inject VaultSessionState Session
@inject NavigationManager Navigation
@inject ISecureRandomGenerator RandomGenerator
@inject ILogger<RecordNewPassword> Logger

<div class="record-create">
    <h1 class="page-title">Новый пароль</h1>
    
    <form @onsubmit="OnSubmit">
        <div class="form-group">
            <label>Название</label>
            <input @bind="title" class="form-input" required placeholder="Например: Google Аккаунт" />
        </div>
        
        <div class="form-group">
            <label>Имя пользователя</label>
            <input @bind="username" class="form-input" placeholder="Email или логин" />
        </div>
        
        <div class="form-group">
            <label>Пароль</label>
            <div class="password-input-group">
                <input @bind="password" type="password" class="form-input" />
                <button type="button" @onclick="GeneratePassword" title="Сгенерировать">
                    <SvgIcon Name="shuffle" Size="20" />
                </button>
            </div>
            <PasswordStrength Password="@password" />
        </div>
        
        <div class="form-group">
            <label>URL (необязательно)</label>
            <input @bind="url" type="url" class="form-input" placeholder="https://example.com" />
        </div>
        
        <div class="form-group">
            <label>Папка (необязательно)</label>
            <input @bind="folder" class="form-input" placeholder="Работа / Личное" />
        </div>
        
        <div class="form-group">
            <label>Теги (через запятую)</label>
            <input @bind="tags" class="form-input" placeholder="работа, важное, google" />
        </div>
        
        <ErrorBanner Message="@errorMessage" />
        
        <div class="form-actions">
            <button type="button" @onclick="Cancel" class="btn btn-secondary">Отмена</button>
            <button type="submit" class="btn btn-primary">Сохранить</button>
        </div>
    </form>
</div>

@code {
    private string title = "";
    private string username = "";
    private string password = "";
    private string url = "";
    private string folder = "";
    private string tags = "";
    private string? errorMessage;

    private async Task OnSubmit()
    {
        if (Session.Repository == null)
        {
            Logger.LogWarning("Cannot create record: repository is null");
            return;
        }

        try
        {
            Logger.LogInformation("Creating new password record: {Title}", title);
            var record = new SecurePasswordRecord(
                RecordId.CreateNew(),
                title,
                username,
                password,
                string.IsNullOrWhiteSpace(url) ? null : url,
                null,
                DateTime.UtcNow
            )
            {
                Folder = string.IsNullOrWhiteSpace(folder) ? null : folder,
                Tags = tags.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Select(t => t.Trim()).ToList()
            };

            await Session.Repository.CreateRecordAsync(record);
            Logger.LogInformation("Password record created successfully: {Title}", title);
            Navigation.NavigateTo("/vault");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create password record: {Title}", title);
            errorMessage = $"Ошибка: {ex.Message}";
        }
    }

    private void GeneratePassword()
    {
        Logger.LogDebug("Generating new random password");
        password = RandomGenerator.GeneratePassword(16, true, true, true, true);
    }

    private void Cancel()
    {
        Logger.LogDebug("Create password cancelled");
        Navigation.NavigateTo("/vault");
    }
}
