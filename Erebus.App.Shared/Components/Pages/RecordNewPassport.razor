@page "/record/new/passport"
@layout MainLayout
@inject VaultSessionState Session
@inject NavigationManager Navigation

<div class="record-create">
    <h1 class="page-title">Новый паспорт / Документ</h1>
    
    <form @onsubmit="OnSubmit">
        <div class="form-group">
            <label>Название</label>
            <input @bind="title" class="form-input" required placeholder="Например: Паспорт РФ" />
        </div>
        
        <div class="form-group">
            <label>ФИО</label>
            <input @bind="fullName" class="form-input" required placeholder="Иванов Иван Иванович" />
        </div>
        
        <div class="form-group">
            <label>Номер документа</label>
            <input @bind="documentNumber" class="form-input" required placeholder="1234 567890" />
        </div>
        
        <div class="form-group">
            <label>Дата рождения</label>
            <input @bind="dateOfBirth" type="date" class="form-input" required />
        </div>
        
        <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label>Дата выдачи</label>
                <input @bind="issueDate" type="date" class="form-input" required />
            </div>
            <div class="form-group">
                <label>Действителен до</label>
                <input @bind="expiryDate" type="date" class="form-input" required />
            </div>
        </div>
        
        <div class="form-group">
            <label>Выдавший орган</label>
            <input @bind="issuingAuthority" class="form-input" required placeholder="МВД России" />
        </div>
        
        <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div class="form-group">
                <label>Код подразделения (необязательно)</label>
                <input @bind="subdivisionCode" class="form-input" placeholder="123-456" />
            </div>
            <div class="form-group">
                <label>Страна</label>
                <input @bind="country" class="form-input" placeholder="RUS" />
            </div>
        </div>
        
        <div class="form-group">
            <label>Папка (необязательно)</label>
            <input @bind="folder" class="form-input" placeholder="Документы" />
        </div>
        
        <div class="form-group">
            <label>Теги (через запятую)</label>
            <input @bind="tags" class="form-input" placeholder="документы, важное" />
        </div>
        
        <ErrorBanner Message="@errorMessage" />
        
        <div class="form-actions">
            <button type="button" @onclick="Cancel" class="btn btn-secondary">Отмена</button>
            <button type="submit" class="btn btn-primary">Сохранить</button>
        </div>
    </form>
</div>

@code {
    private string title = "";
    private string fullName = "";
    private string documentNumber = "";
    private DateTime dateOfBirth = DateTime.Today.AddYears(-18);
    private DateTime issueDate = DateTime.Today;
    private DateTime expiryDate = DateTime.Today.AddYears(10);
    private string issuingAuthority = "";
    private string? subdivisionCode;
    private string country = "RUS";
    private string folder = "";
    private string tags = "";
    private string? errorMessage;
    
    private async Task OnSubmit()
    {
        if (Session.Repository == null) return;
        
        try
        {
            var record = new SecurePassportRecord(
                RecordId.CreateNew(),
                title,
                fullName,
                documentNumber,
                dateOfBirth,
                issueDate,
                expiryDate,
                issuingAuthority,
                string.IsNullOrWhiteSpace(subdivisionCode) ? null : subdivisionCode,
                country,
                DateTime.UtcNow
            )
            {
                Folder = string.IsNullOrWhiteSpace(folder) ? null : folder,
                Tags = tags.Split(',', StringSplitOptions.RemoveEmptyEntries)
                    .Select(t => t.Trim()).ToList()
            };
            
            await Session.Repository.CreateRecordAsync(record);
            Navigation.NavigateTo("/vault");
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
    }
    
    private void Cancel() => Navigation.NavigateTo("/vault");
}
