@page "/record/{Id}/password"
@layout MainLayout
@inject VaultSessionState Session
@inject NavigationManager Navigation
@inject IClipboardService Clipboard

<div class="detail-header">
    <div class="detail-icon">🔑</div>
    <div>
        <div class="detail-title">@record?.Title</div>
        <div class="detail-meta">Пароль</div>
    </div>
</div>

@if (record != null)
{
    <div class="detail-section">
        <h3 class="detail-section-title">Основное</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Имя пользователя</div>
                <div class="copy-field">
                    <input type="text" value="@pr.Username" readonly class="form-input" />
                    <button @onclick="() => CopyToClipboard(pr.Username)" class="btn-icon">📋</button>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Пароль</div>
                <div class="copy-field">
                    <input type="@(showPassword ? "text" : "password")" value="@pr.Password" readonly class="form-input" />
                    <button @onclick="TogglePassword" class="btn-icon">@(showPassword ? "🙈" : "👁️")</button>
                    <button @onclick="() => CopyToClipboard(pr.Password)" class="btn-icon">📋</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(pr.Url))
            {
                <div class="detail-item">
                    <div class="detail-item-label">URL</div>
                    <a href="@pr.Url" target="_blank" class="text-muted">@pr.Url</a>
                </div>
            }
        </div>
    </div>
    
    <div class="detail-section">
        <h3 class="detail-section-title">Метаданные</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Создано</div>
                <div class="detail-item-value">@record.CreatedAt:dd.MM.yyyy HH:mm</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Изменено</div>
                <div class="detail-item-value">@record.ModifiedAt:dd.MM.yyyy HH:mm</div>
            </div>
            @if (record.Folder != null)
            {
                <div class="detail-item">
                    <div class="detail-item-label">Папка</div>
                    <div class="detail-item-value">@record.Folder</div>
                </div>
            }
            @if (record.Tags.Any())
            {
                <div class="detail-item">
                    <div class="detail-item-label">Теги</div>
                    <div class="detail-item-value">
                        @foreach (var tag in record.Tags)
                        {
                            <span class="badge badge-primary">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
    
    <div class="form-actions">
        <button @onclick="DeleteRecord" class="btn btn-danger">🗑️ Удалить</button>
        <button @onclick="EditRecord" class="btn btn-primary">✏️ Редактировать</button>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";
    
    private SecurePasswordRecord? record;
    private SecurePasswordRecord pr => record!;
    private bool showPassword = false;
    
    protected override async Task OnInitializedAsync()
    {
        if (Session.Repository != null)
        {
            var recordId = new RecordId(Id);
            var record = await Session.Repository.GetRecordByIdAsync(recordId);
            this.record = record as SecurePasswordRecord;
        }
    }
    
    private void TogglePassword() => showPassword = !showPassword;
    
    private async Task CopyToClipboard(string text)
    {
        await Clipboard.CopyAsync(text);
    }
    
    private void EditRecord()
    {
        Navigation.NavigateTo($"/record/{Id}/edit");
    }
    
    private async Task DeleteRecord()
    {
        if (Session.Repository != null && record != null)
        {
            await Session.Repository.DeleteRecordAsync(record.Id);
            Navigation.NavigateTo("/vault");
        }
    }
}
