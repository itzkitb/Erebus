@page "/record/{Id}/password"
@layout MainLayout
@inject VaultSessionState Session
@inject NavigationManager Navigation
@inject IClipboardService Clipboard
@inject ILogger<PasswordDetail> Logger

<div class="detail-header">
    <div class="detail-icon">
        <SvgIcon Name="key" Size="40" />
    </div>
    <div>
        <div class="detail-title">@record?.Title</div>
        <div class="detail-meta">Пароль</div>
    </div>
</div>

@if (record != null)
{
    <div class="detail-section">
        <h3 class="detail-section-title">Основное</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Имя пользователя</div>
                <div class="copy-field">
                    <input type="text" value="@pr.Username" readonly class="form-input" />
                    <button @onclick="() => CopyToClipboard(pr.Username)" class="btn-icon">
                        <SvgIcon Name="clipboard" Size="20" />
                    </button>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Пароль</div>
                <div class="copy-field">
                    <input type="@(showPassword ? "text" : "password")" value="@pr.Password" readonly class="form-input" />
                    <button @onclick="TogglePassword" class="btn-icon">
                        <SvgIcon Name="@(showPassword ? "visibility_off" : "visibility")" Size="20" />
                    </button>
                    <button @onclick="() => CopyToClipboard(pr.Password)" class="btn-icon">
                        <SvgIcon Name="clipboard" Size="20" />
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(pr.Url))
            {
                <div class="detail-item">
                    <div class="detail-item-label">URL</div>
                    <a href="@pr.Url" target="_blank" class="text-muted">@pr.Url</a>
                </div>
            }
        </div>
    </div>

    <div class="detail-section">
        <h3 class="detail-section-title">Метаданные</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Создано</div>
                <div class="detail-item-value">@FormatDateTime(record.CreatedAt)</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Изменено</div>
                <div class="detail-item-value">@FormatDateTime(record.ModifiedAt)</div>
            </div>
            @if (record.Folder != null)
            {
                <div class="detail-item">
                    <div class="detail-item-label">Папка</div>
                    <div class="detail-item-value">@record.Folder</div>
                </div>
            }
            @if (record.Tags.Any())
            {
                <div class="detail-item">
                    <div class="detail-item-label">Теги</div>
                    <div class="detail-item-value">
                        @foreach (var tag in record.Tags)
                        {
                            <span class="badge badge-primary">@tag</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="form-actions">
        <button @onclick="DeleteRecord" class="btn btn-danger">
            <SvgIcon Name="delete" Size="18" /> Удалить
        </button>
        <button @onclick="EditRecord" class="btn btn-primary">
            <SvgIcon Name="pencil" Size="18" /> Редактировать
        </button>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private SecurePasswordRecord? record;
    private SecurePasswordRecord pr => record!;
    private bool showPassword = false;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("PasswordDetail page initialized for record: {RecordId}", Id);
        
        if (Session.Repository != null)
        {
            var recordId = new RecordId(Id);
            var record = await Session.Repository.GetRecordByIdAsync(recordId);
            this.record = record as SecurePasswordRecord;
            
            if (this.record != null)
            {
                Logger.LogInformation("Loaded password record: {RecordTitle}", this.record.Title);
            }
            else
            {
                Logger.LogWarning("Password record not found: {RecordId}", Id);
            }
        }
        else
        {
            Logger.LogWarning("Repository is null, cannot load password record");
        }
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
        Logger.LogDebug("Password visibility toggled: {Visible}", showPassword);
    }

    private async Task CopyToClipboard(string text)
    {
        Logger.LogInformation("Copying to clipboard: {FieldType}", text == pr.Password ? "password" : "username");
        await Clipboard.CopyAsync(text);
    }

    private void EditRecord()
    {
        Logger.LogDebug("Navigate to edit record: {RecordId}", Id);
        Navigation.NavigateTo($"/record/{Id}/edit");
    }

    private async Task DeleteRecord()
    {
        if (Session.Repository != null && record != null)
        {
            Logger.LogInformation("Deleting password record: {RecordTitle}", record.Title);
            await Session.Repository.DeleteRecordAsync(record.Id);
            Navigation.NavigateTo("/vault");
        }
    }

    private static string FormatDateTime(DateTime dateTime)
    {
        if (dateTime.Hour == 0 && dateTime.Minute == 0 && dateTime.Second == 0)
        {
            return dateTime.ToString("dd.MM.yyyy");
        }
        return dateTime.ToString("dd.MM.yyyy HH:mm:ss");
    }
}
