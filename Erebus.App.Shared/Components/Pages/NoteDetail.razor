@page "/record/{Id}/note"
@layout MainLayout
@inject VaultSessionState Session
@inject NavigationManager Navigation
@inject ILogger<NoteDetail> Logger

<div class="detail-header">
    <div class="detail-icon">
        <SvgIcon Name="note" Size="40" />
    </div>
    <div>
        <div class="detail-title">@record?.Title</div>
        <div class="detail-meta">Заметка</div>
    </div>
</div>

@if (record != null)
{
    <div class="detail-section">
        <div class="card">
            @if (nr.Format == "md")
            {
                <div style="white-space: pre-wrap; font-family: monospace;">@nr.Content</div>
            }
            else
            {
                @((MarkupString)nr.Content)
            }
        </div>
    </div>
    
    <div class="detail-section">
        <h3 class="detail-section-title">Метаданные</h3>
        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Формат</div>
                <div class="detail-item-value">@(nr.Format == "md" ? "Markdown" : "HTML")</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Создано</div>
                <div class="detail-item-value">@FormatDateTime(record.CreatedAt)</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Изменено</div>
                <div class="detail-item-value">@FormatDateTime(record.ModifiedAt)</div>
            </div>
        </div>
    </div>
    
    <div class="form-actions">
        <button @onclick="DeleteRecord" class="btn btn-danger">
            <SvgIcon Name="delete" Size="18" /> Удалить
        </button>
        <button @onclick="EditRecord" class="btn btn-primary">
            <SvgIcon Name="pencil" Size="18" /> Редактировать
        </button>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private SecureNoteRecord? record;
    private SecureNoteRecord nr => record!;

    protected override async Task OnInitializedAsync()
    {
        Logger.LogInformation("NoteDetail page initialized for record: {RecordId}", Id);
        
        if (Session.Repository != null)
        {
            var recordId = new RecordId(Id);
            var record = await Session.Repository.GetRecordByIdAsync(recordId);
            this.record = record as SecureNoteRecord;
            
            if (this.record != null)
            {
                Logger.LogInformation("Loaded note record: {RecordTitle}", this.record.Title);
            }
            else
            {
                Logger.LogWarning("Note record not found: {RecordId}", Id);
            }
        }
        else
        {
            Logger.LogWarning("Repository is null, cannot load note record");
        }
    }

    private void EditRecord()
    {
        Logger.LogDebug("Navigate to edit note: {RecordId}", Id);
        Navigation.NavigateTo($"/record/{Id}/edit");
    }

    private async Task DeleteRecord()
    {
        if (Session.Repository != null && record != null)
        {
            Logger.LogInformation("Deleting note record: {RecordTitle}", record.Title);
            await Session.Repository.DeleteRecordAsync(record.Id);
            Navigation.NavigateTo("/vault");
        }
    }

    private static string FormatDateTime(DateTime dateTime)
    {
        if (dateTime.Hour == 0 && dateTime.Minute == 0 && dateTime.Second == 0)
        {
            return dateTime.ToString("dd.MM.yyyy");
        }
        return dateTime.ToString("dd.MM.yyyy HH:mm:ss");
    }
}
