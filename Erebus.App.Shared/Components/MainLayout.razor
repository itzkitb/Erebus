@inherits LayoutComponentBase
@using Erebus.App.Shared.State
@inject VaultSessionState Session
@inject IVaultService VaultService
@inject NavigationManager Navigation
@inject ILogger<MainLayout> Logger
@implements IDisposable

<div class="app-layout">
    @if (Session.IsVaultOpen)
    {
        <nav class="sidebar">
            <div class="nav-brand">
                <span class="nav-brand-icon">🔐</span>
                <span>Erebus</span>
            </div>

            <div class="nav-menu">
                <a href="/vault" class="@GetLinkClass("/vault")">
                    <span>📁</span>
                    <span>Хранилище</span>
                </a>
                <a href="/settings" class="@GetLinkClass("/settings")">
                    <span>⚙️</span>
                    <span>Настройки</span>
                </a>
            </div>

            <div style="margin-top: auto;">
                <button @onclick="LockVault" class="btn btn-secondary" style="width: 100%;">
                    🔒 Заблокировать
                </button>
            </div>
        </nav>
    }

    <main class="main-content">
        @Body
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        Logger.LogInformation("MainLayout initialized");
        Session.OnStateChanged += StateHasChanged;
    }

    private string GetLinkClass(string path)
    {
        return "nav-link";
    }

    private async Task LockVault()
    {
        Logger.LogInformation("User initiated vault lock");
        if (Session.CurrentVaultId.HasValue)
        {
            Session.Repository?.Dispose();
            if (Session.CurrentVaultId.HasValue)
            {
                await VaultService.CloseVaultAsync(Session.CurrentVaultId.Value);
            }
            Session.CloseVault();
            Logger.LogInformation("Vault locked successfully");
            Navigation.NavigateTo("/");
        }
    }

    public void Dispose()
    {
        Session.OnStateChanged -= StateHasChanged;
        Logger.LogDebug("MainLayout disposed");
    }
}
